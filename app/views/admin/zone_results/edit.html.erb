<%= render "admin/bar" %>
<main class="admin-wrap" style="max-width: 680px">
  <h1>เขต<%= @zone.name %> (<%= @zone.code %>)</h1>

  <%= form_with url: admin_zone_result_path(@zone), method: :patch do |f| %>
    <section class="admin-card">
      <h2>คะแนนผู้สมัคร</h2>
      <% @candidates.each do |c| %>
        <div class="form-row">
          <label for="votes_<%= c.number %>">เบอร์ <%= c.number %> — <%= c.name %></label>
          <input type="number" min="0" id="votes_<%= c.number %>" name="votes[<%= c.number %>]"
                 value="<%= @existing[c.id]&.votes || 0 %>">
        </div>
      <% end %>
    </section>

    <section class="admin-card">
      <h2>สถิติเขต</h2>
      <% { eligible_voters: "ผู้มีสิทธิ", turnout: "มาใช้สิทธิ", bad_ballots: "บัตรเสีย",
           no_vote: "ไม่ประสงค์ฯ", counted_percent: "นับแล้ว (%)" }.each do |field, label| %>
        <div class="form-row">
          <label for="stats_<%= field %>"><%= label %></label>
          <input type="number" min="0" step="<%= field == :counted_percent ? '0.1' : '1' %>"
                 <%= 'max="100"' if field == :counted_percent %>
                 id="stats_<%= field %>" name="stats[<%= field %>]"
                 value="<%= @stat.public_send(field) %>">
        </div>
      <% end %>
    </section>

    <label class="confirm-row">
      <input type="checkbox" name="confirm" value="1">
      <span>ตรวจสอบตัวเลขแล้ว ยืนยันบันทึก (ลงประวัติในชื่อ <%= Current.user.email_address %>)</span>
    </label>

    <div style="display: flex; gap: 10px; align-items: center">
      <%= f.submit "บันทึกผลเขตนี้", class: "btn btn-primary" %>
      <%= link_to "ยกเลิก", admin_root_path, class: "btn btn-ghost" %>
    </div>
  <% end %>
</main>
