<%= render "admin/bar" %>
<main class="admin-wrap">
  <h1>ประวัติการแก้ไข (ล่าสุด 200 รายการ)</h1>

  <section class="admin-card">
    <table class="admin-table">
      <thead><tr>
        <th>เวลา</th>
        <th>รายการ</th>
        <th>เดิม → ใหม่</th>
        <th>ที่มา</th>
        <th>ผู้แก้</th>
      </tr></thead>
      <tbody>
        <% @revisions.each do |rev| %>
          <tr>
            <td class="num"><%= rev.created_at.strftime("%d/%m %H:%M:%S") %></td>
            <td><%= rev.recordable_type %> #<%= rev.recordable_id %></td>
            <td class="num"><%= rev.old_values %> → <%= rev.new_values %></td>
            <td><%= rev.source %></td>
            <td><%= rev.editor || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <p style="margin-top: 10px; color: var(--muted); font-size: 13px">
      ย้อนคะแนน: เปิดหน้าแก้ไขเขตนั้น กรอกค่า "เดิม" จากตารางนี้ แล้วบันทึก (ระบบบันทึกเป็น revision ใหม่ — ไม่ลบประวัติ)
    </p>
  </section>
</main>
