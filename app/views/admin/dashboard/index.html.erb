<%= render "admin/bar" %>
<main class="admin-wrap">
  <h1>ภาพรวมการนับคะแนน</h1>

  <section class="admin-card">
    <div class="mode-line">
      <span>โหมดข้อมูล:</span>
      <span class="mode-pill <%= @election.api? ? "api" : "manual" %>">
        <span class="dot"></span>
        <%= @election.api? ? "API อัตโนมัติ" : "MANUAL — ทีมงานกรอกมือ (API ถูกพัก)" %>
      </span>
      <%= button_to @election.api? ? "สลับเป็นโหมดกรอกมือ (พัก API)" : "สลับกลับเป็นโหมด API",
            toggle_mode_admin_election_path, method: :patch,
            class: "btn #{@election.api? ? 'btn-ghost' : 'btn-primary'} btn-sm",
            data: { turbo_confirm: "ยืนยันการสลับโหมดข้อมูล? มีผลต่อหน้าเว็บสาธารณะทันที" } %>
    </div>
  </section>

  <section class="admin-card">
    <h2>กรอก/แก้คะแนนรายเขต</h2>
    <table class="admin-table">
      <thead><tr>
        <th>เขต</th>
        <th class="r">นับแล้ว</th>
        <th></th>
      </tr></thead>
      <tbody>
        <% @zones.each do |zone| %>
          <tr>
            <td><%= zone.code %> <%= zone.name %></td>
            <td class="r num"><%= zone.zone_stat&.counted_percent || 0 %>%</td>
            <td class="r"><%= link_to "แก้ไข", edit_admin_zone_result_path(zone), class: "btn btn-ghost btn-sm" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</main>
