<header class="site-head">
  <div class="topbar-row">
    <%= render "shared/election_tabs" %>
    <div class="topbar-right">
      <div class="live"><span class="dot"></span>LIVE</div>
      <button type="button" class="theme-toggle" data-controller="theme" data-action="theme#toggle"
              aria-label="สลับธีมสว่าง/มืด">
        <svg class="ico-moon" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z"/></svg>
        <svg class="ico-sun" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      </button>
    </div>
  </div>
  <div class="inner">
    <div class="brand">
      <%= image_tag "logo-dn-pink-04.webp", alt: "เดลินิวส์", class: "logo-img" %>
      <div class="event"><%= local_assigns.fetch(:title, "เลือกตั้งผู้ว่าฯ กทม. 2569") %></div>
    </div>
    <% if local_assigns[:election] %>
      <%= render "dashboard/header_status", election: election %>
    <% end %>
  </div>
</header>
