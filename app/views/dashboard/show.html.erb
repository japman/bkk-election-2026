<%# Countdown splash — บังหน้าผลจนถึง 08:00 28 มิ.ย. (หรือคลิก 10 ครั้งเพื่อ preview) %>
<div id="countdown" class="countdown-splash"
     data-controller="countdown"
     data-countdown-target-value="2026-06-28T08:00:00+07:00"
     data-countdown-clicks-to-close-value="10"
     role="dialog" aria-label="นับถอยหลังสู่การประกาศผลเลือกตั้ง" hidden>
  <div class="cd-inner">
    <p class="cd-kicker">เลือกตั้งผู้ว่าราชการกรุงเทพมหานคร 2569</p>
    <h1 class="cd-title">ระบบรายงานผลเริ่ม<br><span class="cd-time">08:00 น. 28 มิถุนายน 2569</span></h1>
    <div class="cd-timer num" aria-hidden="true">
      <div class="cd-unit"><span class="cd-num" data-countdown-target="days">--</span><span class="cd-lbl">วัน</span></div>
      <span class="cd-sep">:</span>
      <div class="cd-unit"><span class="cd-num" data-countdown-target="hours">--</span><span class="cd-lbl">ชม.</span></div>
      <span class="cd-sep">:</span>
      <div class="cd-unit"><span class="cd-num" data-countdown-target="minutes">--</span><span class="cd-lbl">นาที</span></div>
      <span class="cd-sep">:</span>
      <div class="cd-unit"><span class="cd-num" data-countdown-target="seconds">--</span><span class="cd-lbl">วินาที</span></div>
    </div>
    <p class="cd-foot">โดยทีมข่าวเดลินิวส์</p>
  </div>
</div>
<script>
  // anti-flash: โชว์ splash ก่อน paint เฉพาะเมื่อยังไม่ถึงเวลา และยังไม่เคยปิดในเครื่องนี้
  (function () {
    var el = document.getElementById("countdown");
    if (!el) return;
    var target = new Date("2026-06-28T08:00:00+07:00").getTime();
    var dismissed = false;
    try { dismissed = localStorage.getItem("bkk2026-countdown-dismissed") === "1"; } catch (e) {}
    if (Date.now() < target && !dismissed) el.hidden = false;
  })();
</script>

<% if @election.nil? %>
  <%= render "site_header" %>
  <main class="wrap"><p>ยังไม่เปิดรายงานผล</p></main>
<% else %>
  <% if @election.live_streaming? %>
    <%= turbo_stream_from "results" %>
  <% end %>
  <div data-controller="live-flash fallback"
       data-fallback-stale-after-value="<%= @election.live_streaming? ? 15000 : 0 %>">
    <%= render "site_header", election: @election %>
    <%= render "hero", election: @election %>
    <main class="wrap">
      <%= render "leaderboard", election: @election %>
      <%= render "map", election: @election %>
      <%= render "stats", election: @election %>
      <%= turbo_frame_tag "news_panel", src: news_path, loading: "lazy", class: "sec-news" do %>
        <section class="card">
          <div class="card-head">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h13v14H6a2 2 0 0 1-2-2V5Z"/><path d="M17 8h3v9a2 2 0 0 1-2 2h-1M8 9h5M8 13h5M8 17h3"/></svg>
            <h2>เกาะติดจาก Dailynews</h2>
          </div>
          <p style="padding: 14px 16px; color: var(--muted)">กำลังโหลดข่าว…</p>
        </section>
      <% end %>
    </main>
  </div>
  <footer>
    ผลคะแนนอย่างไม่เป็นทางการ — รวบรวมโดยทีมข่าวเดลินิวส์
    <div class="credits">
      Consent by <a href="https://consentrix.odds.team" target="_blank" rel="noopener">consentrix.odds.team</a>
      <span aria-hidden="true">·</span>
      Developed by <a href="https://odt.co.th" target="_blank" rel="noopener">odt.co.th</a>
    </div>
  </footer>
<% end %>
