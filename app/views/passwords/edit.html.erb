<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="logo">DAILY<span>NEWS</span></div>
      <div class="sub">ตั้งรหัสผ่านใหม่</div>
    </div>

    <%= form_with url: password_path(params[:token]), method: :put do |form| %>
      <div class="field">
        <%= form.label :password, "รหัสผ่านใหม่" %>
        <%= form.password_field :password, required: true,
              autocomplete: "new-password", maxlength: 72 %>
      </div>
      <div class="field">
        <%= form.label :password_confirmation, "ยืนยันรหัสผ่านใหม่" %>
        <%= form.password_field :password_confirmation, required: true,
              autocomplete: "new-password", maxlength: 72 %>
      </div>
      <%= form.submit "บันทึกรหัสผ่าน", class: "btn btn-primary btn-block" %>
    <% end %>
  </div>
</div>
