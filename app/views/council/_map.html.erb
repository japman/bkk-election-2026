<% zones = election.zones.includes(:zone_stat, vote_results: :candidate).sort_by(&:code) %>
<div id="council-map">
  <div class="map-zoom" data-controller="map-zoom">
    <div class="map-zoom-vp" data-map-zoom-target="vp">
      <div class="map-grid" data-map-zoom-target="canvas">
  <% zones.each do |z|
       w = z.vote_results.max_by(&:votes)&.candidate %>
    <button class="tile" data-zone-code="<%= z.code %>" data-action="council#show"
            style="--c: <%= w&.color || '#C9CFD6' %>; grid-column: <%= z.grid_col %>; grid-row: <%= z.grid_row %>"
            aria-label="เขต<%= z.name %><%= " ผู้ชนะ #{w.name}" if w %>"><span><%= z.name %></span></button>
  <% end %>
      </div>
    </div>
    <div class="map-zoom-ctl">
      <button type="button" data-action="map-zoom#zoomOut" aria-label="ซูมออก">−</button>
      <button type="button" data-action="map-zoom#reset" aria-label="รีเซ็ตการซูม">⟲</button>
      <button type="button" data-action="map-zoom#zoomIn" aria-label="ซูมเข้า">+</button>
    </div>
  </div>
</div>
